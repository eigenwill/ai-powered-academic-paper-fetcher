# ── Required ──────────────────────────────────────────────────────────────────

# Zotero API credentials
# Create a key at https://www.zotero.org/settings/keys (needs read/write access)
ZOTERO_API_KEY=your_zotero_api_key_here
ZOTERO_USER_ID=your_zotero_user_id_here
ZOTERO_LIBRARY_TYPE=user   # 'user' or 'group'

# Unpaywall — any valid email (used for polite-pool rate limiting)
UNPAYWALL_EMAIL=your@email.com

# ── LLM (only needed for --smart flag) ────────────────────────────────────────

# Defaults to Gemini Flash. Set one of the following matching your provider:
LLM_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Semantic Scholar API key — higher rate limits; request at:
# https://www.semanticscholar.org/product/api
# S2_API_KEY=

# WebVPN portal base URL (defaults to Fudan University)
# WEBVPN_BASE=https://webvpn.fudan.edu.cn

# Zotero Translation Server (optional local enrichment)
# USE_TRANSLATION_SERVER=false
# TRANSLATION_SERVER_URL=http://localhost:1969

# ── Storage paths (auto-created, override if needed) ──────────────────────────
# DATA_DIR=~/.paper-fetch
# CACHE_DIR=~/.paper-fetch/cache
# DOWNLOAD_DIR=~/.paper-fetch/downloads
# PLAYWRIGHT_USER_DATA_DIR=~/.paper-fetch/chromium-profile
